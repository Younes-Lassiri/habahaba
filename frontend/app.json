{
  "expo": {
    "splash": {
      "image": "./assets/images/playStoreLogo.png",
      "backgroundColor": "#ffffff",
      "resizeMode": "contain"
    },
    "name": "HabaHaba Food Delivery",
    "slug": "lamadone-food-delivery-app",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/images/playStoreLogo.png",
    "scheme": "restaurantapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your friends.",
          "cameraPermission": "The app accesses your camera to let you take profile photos."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": false,
            "enableMinifyInReleaseBuilds": false
          }
        }
      ],
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/playStoreLogo.png",
          "androidMode": "badge",
          "androidCollapsedTitle": "New Order",
          "channels": [
            {
              "id": "new-order-alert",
              "name": "New Order Alert",
              "priority": "max",
              "importance": "max",
              "vibrationPattern": [
                0,
                250,
                250,
                250
              ],
              "sound": "newOrderAlert.mp3"
            }
          ]
        }
      ],
      "expo-router",
      "./withNotificationConflict.js"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.younesthegoat.restaurantapp",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ],
        "NSLocationWhenInUseUsageDescription": "This app needs access to your location to set your address automatically",
        "NSLocationAlwaysUsageDescription": "This app needs access to your location to provide location-based features.",
        "NSCameraUsageDescription": "This app uses the camera to take profile pictures.",
        "NSPhotoLibraryUsageDescription": "This app needs access to your photos to upload profile pictures.",
        "NSPhotoLibraryAddUsageDescription": "This app needs permission to save the selected photo.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "googleMapsApiKey": "AIzaSyCx4qoEgZzG3A7VW9_gxpEWAqMSeNs_DfY"
      }
    },
    "android": {
      "package": "com.younesthegoat.restaurantapp",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/playStoreLogo.png",
        "backgroundImage": "./assets/images/playStoreLogo.png",
        "monochromeImage": "./assets/images/playStoreLogo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCx4qoEgZzG3A7VW9_gxpEWAqMSeNs_DfY"
        }
      },
      "versionCode": 3
    },
    "owner": "lassirihaba",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/2c668a43-9389-4f47-ba21-8ad66c4bb6dd",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "extra": {
      "eas": {
        "projectId": "174efa9e-18f0-4597-8a6a-9fcc5748acef"
      },
      "router": {}
    }
  }
}
